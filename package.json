{
  "name": "deassert-mono",
  "version": "0.0.0-development",
  "private": true,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RebeccaStevens/deassert"
  },
  "license": "BSD-3-Clause",
  "author": {
    "name": "Rebecca Stevens",
    "email": "rebecca.stevens@outlook.co.nz"
  },
  "type": "module",
  "scripts": {
    "build": "pnpm --stream -r build",
    "lint": "eslint && pnpm run lint:md && pnpm run lint:spelling && pnpm run lint:knip && pnpm run lint:packages",
    "lint:js": "eslint \"**/*.?([cm])[jt]s?(x)\"",
    "lint:js-fix": "eslint \"**/*.?([cm])[jt]s?(x)\" --fix",
    "lint:knip": "knip",
    "lint:md": "markdownlint-cli2",
    "lint:md-fix": "markdownlint-cli2 --fix",
    "lint:md-full": "pnpm run lint:md && eslint \"**/*.md\"",
    "lint:md-full-fix": "pnpm run lint:md-fix && eslint \"**/*.md\" --fix",
    "lint:packages": "pnpm dedupe --check",
    "lint:packages-fix": "pnpm dedupe",
    "lint:spelling": "cspell lint --no-progress --show-suggestions --show-context --dot \"**\" \".github/**/*\"",
    "lint:yaml": "eslint \"**/*.y?(a)ml\"",
    "lint:yaml-fix": "eslint \"**/*.y?(a)ml\" --fix",
    "lint-fix": "eslint --fix && pnpm run lint:md-fix && pnpm run lint:packages-fix",
    "prepare": "husky",
    "release": "pnpm -r --workspace-concurrency=1 release",
    "test": "pnpm --stream -r test:js-run",
    "typecheck": "pnpm --stream -r typecheck"
  },
  "devDependencies": {
    "@eslint-community/eslint-plugin-eslint-comments": "4.7.1",
    "@eslint/compat": "2.0.3",
    "@eslint/markdown": "8.0.0",
    "@rebeccastevens/eslint-config": "3.9.7",
    "@stylistic/eslint-plugin": "5.10.0",
    "@types/node": "22.19.15",
    "@typescript-eslint/eslint-plugin": "8.57.2",
    "@typescript-eslint/parser": "8.57.2",
    "@vitest/eslint-plugin": "1.6.13",
    "cspell": "9.8.0",
    "eslint": "10.2.1",
    "eslint-config-prettier": "10.1.8",
    "eslint-flat-config-utils": "3.0.2",
    "eslint-formatting-reporter": "0.0.0",
    "eslint-import-resolver-typescript": "4.4.4",
    "eslint-merge-processors": "2.0.0",
    "eslint-plugin-format": "2.0.1",
    "eslint-plugin-functional": "9.0.4",
    "eslint-plugin-import-x": "4.16.2",
    "eslint-plugin-jsdoc": "62.8.1",
    "eslint-plugin-jsonc": "3.1.2",
    "eslint-plugin-n": "17.24.0",
    "eslint-plugin-no-only-tests": "3.3.0",
    "eslint-plugin-optimize-regex": "1.2.1",
    "eslint-plugin-prettier": "5.5.5",
    "eslint-plugin-promise": "7.2.1",
    "eslint-plugin-regexp": "3.1.0",
    "eslint-plugin-sonarjs": "4.0.2",
    "eslint-plugin-unicorn": "64.0.0",
    "eslint-plugin-yml": "3.3.1",
    "husky": "9.1.7",
    "jiti": "2.6.1",
    "jsonc-eslint-parser": "3.1.0",
    "knip": "6.1.0",
    "lint-staged": "16.4.0",
    "markdownlint-cli2": "0.22.0",
    "prettier": "3.8.1",
    "sort-package-json": "3.6.1",
    "tsc-files": "1.1.4",
    "typescript": "6.0.2",
    "yaml-eslint-parser": "2.0.0"
  },
  "packageManager": "pnpm@10.33.0"
}
