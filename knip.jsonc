{
  "$schema": "node_modules/knip/schema-jsonc.json",
  "workspaces": {
    "packages/*": {
      "entry": ["src/index.{js,ts}"],
      "project": ["**/*.{js,ts}"],
    },
  },
  // TODO: Figure out why these are reported as unused.
  "ignore": ["common/**/*.{js,ts}"],
  "ignoreDependencies": [
    // Lint staged
    "tsc-files",

    // Eslint
    "@eslint/compat",
  ],
}
