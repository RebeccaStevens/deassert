{
  "$schema": "node_modules/knip/schema-jsonc.json",
  "workspaces": {
    "packages/*": {
      "entry": ["src/index.ts!", "src/cli.ts!", "tests/**/*.test.ts"],
      "project": ["src/**/*.ts!", "tests/**/*.{js,ts}"],
    },
  },
  "ignoreDependencies": [
    // Lint staged
    "tsc-files",

    // Eslint
    "@eslint/compat",
  ],
}
