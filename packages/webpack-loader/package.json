{
  "name": "deassert-loader",
  "version": "0.0.0-development",
  "description": "webpack loader for deassert",
  "keywords": [
    "assert",
    "deassert",
    "invariant",
    "unassert",
    "webpack",
    "loader"
  ],
  "homepage": "https://github.com/RebeccaStevens/deassert/tree/main/packages/webpack-loader#readme",
  "bugs": {
    "url": "https://github.com/RebeccaStevens/deassert/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RebeccaStevens/deassert"
  },
  "funding": [
    {
      "type": "ko-fi",
      "url": "https://ko-fi.com/rebeccastevens"
    },
    {
      "type": "tidelift",
      "url": "https://tidelift.com/funding/github/npm/deassert"
    }
  ],
  "license": "BSD-3-Clause",
  "author": {
    "name": "Rebecca Stevens",
    "email": "rebecca.stevens@outlook.co.nz"
  },
  "type": "module",
  "exports": {
    "types": "./dist/index.d.cts",
    "default": "./dist/index.cjs"
  },
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.cts",
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "rimraf dist && rollup -c rollup.config.ts",
    "lint": "eslint && pnpm run lint:spelling && pnpm run lint:packages",
    "lint:js": "eslint \"**/*.?([cm])[jt]s?(x)\"",
    "lint:js-fix": "eslint \"**/*.?([cm])[jt]s?(x)\" --fix",
    "lint:packages": "pnpm dedupe --check",
    "lint:packages-fix": "pnpm dedupe",
    "lint:spelling": "cspell lint --no-progress --show-suggestions --show-context --dot \"**\" \".github/**/*\"",
    "lint:yaml": "eslint \"**/*.y?(a)ml\"",
    "lint:yaml-fix": "eslint \"**/*.y?(a)ml\" --fix",
    "lint-fix": "eslint --fix && pnpm run lint:packages-fix",
    "release": "pnpm dlx --package semantic-release --package semantic-release-monorepo --package @semantic-release/changelog --package @semantic-release/commit-analyzer --package @semantic-release/git --package @semantic-release/github --package @semantic-release/npm --package @semantic-release/release-notes-generator --package semantic-release-publint semantic-release",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "acorn": "^8.12.1",
    "deassert": "workspace:*"
  },
  "devDependencies": {
    "@rollup/plugin-typescript": "12.3.0",
    "@types/webpack": "5.28.5",
    "rimraf": "6.1.3",
    "rollup": "4.59.0",
    "rollup-plugin-dts-bundle-generator-2": "2.0.0",
    "typescript": "5.9.3"
  },
  "packageManager": "pnpm@10.30.3"
}
