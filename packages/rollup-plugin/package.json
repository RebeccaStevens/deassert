{
  "name": "rollup-plugin-deassert",
  "version": "0.0.0-development",
  "description": "rollup plugin for deassert",
  "keywords": [
    "assert",
    "deassert",
    "invariant",
    "unassert",
    "rollup",
    "rollup-plugin"
  ],
  "homepage": "https://github.com/RebeccaStevens/deassert/tree/main/packages/rollup-plugin#readme",
  "bugs": {
    "url": "https://github.com/RebeccaStevens/deassert/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RebeccaStevens/deassert.git"
  },
  "funding": [
    {
      "type": "ko-fi",
      "url": "https://ko-fi.com/rebeccastevens"
    },
    {
      "type": "tidelift",
      "url": "https://tidelift.com/funding/github/npm/deassert"
    }
  ],
  "license": "BSD-3-Clause",
  "author": {
    "name": "Rebecca Stevens",
    "email": "rebecca.stevens@outlook.co.nz"
  },
  "type": "module",
  "exports": {
    "types": {
      "import": "./dist/index.d.mts",
      "require": "./dist/index.d.cts"
    },
    "import": "./dist/index.mjs",
    "require": "./dist/index.cjs"
  },
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "rimraf dist && rollup -c rollup.config.ts --configPlugin @rollup/plugin-typescript --configImportAttributesKey with",
    "lint": "eslint && pnpm run lint:md && pnpm run lint:spelling && pnpm run lint:knip && pnpm run lint:package",
    "lint:js": "eslint \"**/*.?([cm])[jt]s?(x)\"",
    "lint:js-fix": "eslint \"**/*.?([cm])[jt]s?(x)\" --fix",
    "lint:knip": "knip -c \"../../knip.jsonc\"",
    "lint:md": "markdownlint-cli2 --config \"../../.markdownlint-cli2.jsonc\"",
    "lint:md-fix": "markdownlint-cli2 --config \"../../.markdownlint-cli2.jsonc\" --fix",
    "lint:md-full": "pnpm run lint:md && eslint \"**/*.md\"",
    "lint:md-full-fix": "pnpm run lint:md-fix && eslint \"**/*.md\" --fix",
    "lint:package": "publint --strict",
    "lint:spelling": "cspell lint --no-progress --show-suggestions --show-context --dot \"**\" \".github/**/*\"",
    "lint:yaml": "eslint \"**/*.y?(a)ml\"",
    "lint:yaml-fix": "eslint \"**/*.y?(a)ml\" --fix",
    "lint-fix": "eslint --fix && pnpm run lint:md-fix",
    "test": "echo \"No tests\"",
    "test:js": "echo \"No tests\"",
    "test:js-run": "echo \"No tests\"",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@rollup/pluginutils": "^5.1.2",
    "deassert": "workspace:deassert"
  },
  "devDependencies": {
    "@eslint-community/eslint-plugin-eslint-comments": "4.7.1",
    "@eslint/compat": "2.0.2",
    "@eslint/markdown": "7.5.1",
    "@rebeccastevens/eslint-config": "3.9.6",
    "@rollup/plugin-typescript": "12.3.0",
    "@stylistic/eslint-plugin": "5.9.0",
    "@types/node": "22.19.13",
    "@typescript-eslint/eslint-plugin": "8.56.1",
    "@typescript-eslint/parser": "8.56.1",
    "acorn": "^8.12.1",
    "cspell": "9.7.0",
    "dts-bundle-generator": "9.5.1",
    "eslint": "10.0.2",
    "eslint-config-prettier": "10.1.8",
    "eslint-flat-config-utils": "3.0.1",
    "eslint-formatting-reporter": "0.0.0",
    "eslint-import-resolver-typescript": "4.4.4",
    "eslint-merge-processors": "2.0.0",
    "eslint-plugin-format": "2.0.1",
    "eslint-plugin-functional": "9.0.4",
    "eslint-plugin-import-x": "4.16.1",
    "eslint-plugin-jsdoc": "62.7.1",
    "eslint-plugin-jsonc": "3.1.1",
    "eslint-plugin-n": "17.24.0",
    "eslint-plugin-no-only-tests": "3.3.0",
    "eslint-plugin-optimize-regex": "1.2.1",
    "eslint-plugin-prettier": "5.5.5",
    "eslint-plugin-promise": "7.2.1",
    "eslint-plugin-regexp": "3.0.0",
    "eslint-plugin-sonarjs": "4.0.0",
    "eslint-plugin-unicorn": "63.0.0",
    "eslint-plugin-yml": "3.3.0",
    "jiti": "2.6.1",
    "jsonc-eslint-parser": "3.1.0",
    "knip": "5.85.0",
    "markdownlint-cli2": "0.21.0",
    "prettier": "3.8.1",
    "publint": "0.3.18",
    "rimraf": "6.1.3",
    "rollup": "4.59.0",
    "rollup-plugin-dts-bundle-generator-2": "2.0.0",
    "sort-package-json": "3.6.1",
    "tsc-files": "1.1.4",
    "tslib": "2.8.1",
    "typescript": "5.9.3",
    "yaml-eslint-parser": "2.0.0"
  },
  "peerDependencies": {
    "acorn": "^8.12.1",
    "rollup": "^4.22.4"
  },
  "packageManager": "pnpm@10.30.3"
}
